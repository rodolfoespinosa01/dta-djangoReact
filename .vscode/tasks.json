{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Django Server",
      "type": "shell",
      "command": "source venv/bin/activate && python manage.py runserver",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Run React App",
      "type": "shell",
      "command": "zsh -c 'source ~/.nvm/nvm.sh && nvm install && nvm use && npm start'",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      }
    },
    {
      "label": "Run Redis Server",
      "type": "shell",
      "command": "redis-server",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Celery Worker",
      "type": "shell",
      "command": "source venv/bin/activate && celery -A core worker -l info",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Stripe Webhook",
      "type": "shell",
      "command": "stripe listen --forward-to http://localhost:8000/api/v1/users/admin/stripe_webhook/",
      "options": { "cwd": "${workspaceFolder}" }
    },
    {
      "label": "Start All Services",
      "dependsOn": [
        "Run Redis Server",
        "Run Celery Worker",
        "Run Django Server",
        "Run React App",
        "Run Stripe Webhook"
      ],
      "dependsOrder": "parallel"
    },
    {
      "label": "Run Machine Update Script",
      "type": "shell",
      "command": "./machineupdate.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": []
    },
    {
      "label": "Run Django Tests",
      "type": "shell",
      "command": "source venv/bin/activate && python manage.py test",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Reset All",
      "type": "shell",
      "command": "source venv/bin/activate && python manage.py reset_all",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    },
    {
      "label": "Full Reset DB",
      "type": "shell",
      "command": "source venv/bin/activate && python manage.py full_reset_db",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": []
    }
  ]
}
